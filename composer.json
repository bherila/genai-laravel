{
    "name": "bherila/genai-laravel",
    "description": "Provider-agnostic GenAI client for Laravel: Gemini, AWS Bedrock, and more",
    "type": "library",
    "keywords": ["laravel", "gemini", "bedrock", "ai", "genai", "llm"],
    "license": "MIT",
    "authors": [
        {
            "name": "Ben Herila",
            "email": "ben@herila.net"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12|^13",
        "illuminate/support": "^12|^13",
        "illuminate/http": "^12|^13"
    },
    "require-dev": {
        "orchestra/testbench": "^10|^11",
        "phpoffice/phpspreadsheet": "^4|^5",
        "phpunit/phpunit": "^10|^11",
        "laravel/pint": "^1"
    },
    "suggest": {
        "phpoffice/phpspreadsheet": "Required for automatic XLSX / XLS / ODS → plain-text conversion when sending spreadsheet files to Anthropic or Gemini (^4|^5)."
    },
    "autoload": {
        "psr-4": {
            "Bherila\\GenAiLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bherila\\GenAiLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bherila\\GenAiLaravel\\GenAiServiceProvider"
            ],
            "aliases": {
                "GenAi": "Bherila\\GenAiLaravel\\Facades\\GenAi"
            }
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
